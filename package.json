{
  "name": "llm-guardrails",
  "version": "0.7.1",
  "description": "LLM guardrails middleware — PII, injection, toxicity, schema validation, and policy engine",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "ui-dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:ui && tsc",
    "build:ui": "npm run build --prefix ui",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "axios": "^1.7.2",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.5"
  },
  "keywords": [
    "llm",
    "guardrails",
    "pii",
    "prompt-injection",
    "toxicity",
    "policy"
  ],
  "license": "MIT"
}
